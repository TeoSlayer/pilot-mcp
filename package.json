    "model-context-protocol",
    "pilot",
    "pilot-protocol",
    "agent",
    "agent-network",
    "p2p",
    "overlay-network",
    "a2a",
    "agent-to-agent",
    "specialists",
    "claude-code",
    "cursor",
    "cline",
    "hermes",
    "openclaw",
    "openhands",
    "continue",
    "codex"
  ],
