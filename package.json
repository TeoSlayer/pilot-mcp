  "homepage": "https://pilotprotocol.network",
  "repository": {
    "type": "git",
    "url": "https://github.com/pilot-protocol/pilot-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/pilot-protocol/pilot-mcp/issues"
  }
